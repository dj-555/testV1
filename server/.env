# HTTP server bind settings
SERVER_HOST=0.0.0.0
PORT=3000

# CORS/origin rules: use * for development, or comma-separated origins in production.
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*
REQUIRE_ORIGIN=false

# Set true if running behind reverse proxy (nginx, HAProxy, cloud LB)
TRUST_PROXY=false

# Optional client IP allowlist (comma-separated). Empty means allow all.
# Example: ALLOWED_CLIENT_IPS=203.0.113.10,198.51.100.20
ALLOWED_CLIENT_IPS=

# Optional socket auth shared secret. If set, clients must send it as auth.token.
SOCKET_SHARED_SECRET=

# mediasoup network and ports
MEDIASOUP_LISTEN_IP=0.0.0.0
# For public deployment, set this to your public server IP.
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_MIN_PORT=20000
MEDIASOUP_MAX_PORT=29999
MEDIASOUP_LOG_LEVEL=warn

# Extra runtime logs
DEBUG_LOGS=true
